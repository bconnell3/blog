---
const {title, date, desc, url, linktext} = Astro.props;

function getOrdinalSuffix(day: number) {
  const rules = new Intl.PluralRules('en-US', { type: 'ordinal' });
  const suffixes: Record<string, string> = { one: 'st', two: 'nd', few: 'rd', other: 'th' };
  return suffixes[rules.select(day)];
}

function formatDate(dateStr: string) {
  const date = new Date(dateStr);
  const day = date.getDate();
  const month = date.toLocaleDateString('en-US', { month: 'long' });
  const year = date.getFullYear();
  return `${month} ${day}${getOrdinalSuffix(day)}, ${year}`;
}

function truncate(str: string, maxLength: number = 315) {
  if (str.length <= maxLength) return str;
  const trimmed = str.slice(0, maxLength);
  return trimmed.slice(0, trimmed.lastIndexOf(' ')) + '…';
}
---
<style>
  article {
    margin-bottom: 60px;
    .date {
      margin-left: 20px;
      font-family: "Playwrite US Trad", cursive;
      color: #7d7373;
    }
    .btn {
      padding: 16px 30px;
      background-color: #efcd51;
      color: #453b4a;
      text-decoration: none;
      font-size: clamp(1rem, 0.9716rem + 0.142vw, 1.125rem);
      border-radius: 6px;
      &:hover {
        background-color: #f2d773;
      }
    }
  }
</style>

<article>
    <h3>{title}</h3>
    <p class="date">{formatDate(date)}</p>
    <p>{truncate(desc)}</p>
    <a class="btn" href={url}>{linktext}</a>
</article>