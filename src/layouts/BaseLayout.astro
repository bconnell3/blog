---
import '@fontsource/playwrite-us-trad';
import '@fontsource-variable/geologica/wght.css';
import '../css/styles.css';
import Header from '../components/Header.astro';
const { pageTitle } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{pageTitle}</title>
		<meta name="description" content="UI design, HTML, and CSS explained simply. Fundamentals I teach my students, plus my personal projects and ongoing explorations in front-end design.">
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="Bridgette's Blog" />
		<link rel="manifest" href="/site.webmanifest" />
	</head>
	<body>
		<Header />

		<main class="inner-container flex">
			<slot />
		</main>
	</body>
</html>
